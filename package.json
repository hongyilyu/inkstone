{
	"name": "inkstone",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"dev:web": "pnpm --filter @inkstone/web dev",
		"check:ts": "pnpm -r --if-present check",
		"check:rust": "cargo check --manifest-path crates/core/Cargo.toml",
		"check": "pnpm check:ts && pnpm check:rust",
		"test:e2e": "pnpm -C tests/e2e test:e2e",
		"test:e2e:install": "pnpm -C tests/e2e test:e2e:install",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"biome:fix": "biome check --write ."
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "^11.1.3",
			"onFail": "download"
		}
	},
	"type": "module",
	"devDependencies": {
		"@biomejs/biome": "2.4.15"
	},
	"private": true
}
