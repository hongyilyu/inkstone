{
  "name": "inkstone",
  "version": "0.1.0",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "dev:log": "KIRO_LOG=debug KIRO_LOG_FILE=/tmp/inkstone-kiro.log bun run --watch src/index.tsx",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "check": "biome check --write ./src",
    "test": "bun test --timeout 30000",
    "ci": "biome check ./src && bun test --timeout 30000"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@mariozechner/pi-agent-core": "^0.69.0",
    "@mariozechner/pi-ai": "^0.69.0",
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "@opentui/core": "^0.1.99",
    "@opentui/solid": "^0.1.99",
    "@sinclair/typebox": "^0.34.49",
    "@solid-primitives/event-bus": "^1.1.3",
    "babel-preset-solid": "1.9.9",
    "diff": "^9.0.0",
    "drizzle-orm": "^0.45.2",
    "fuzzysort": "^3.1.0",
    "open": "^11.0.0",
    "pi-kiro": "^0.1.2",
    "remeda": "^2.33.7",
    "solid-js": "1.9.9",
    "zod": "^4"
  }
}
