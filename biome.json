{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"files": {
		"includes": ["src/**/*.{ts,tsx}", "test/**/*.{ts,tsx}"]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": "off",
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/backend/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": ["@tui/*", "**/tui/**"],
										"message": "backend/ cannot import from tui/. Covers both the @tui/* alias and any relative path that climbs into tui/."
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["src/bridge/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": ["@tui/*", "**/tui/**"],
										"message": "bridge/ cannot import from tui/. Covers both the @tui/* alias and any relative path that climbs into tui/."
									},
									{
										"group": ["@backend/*", "**/backend/**"],
										"message": "bridge/ cannot import from backend/. Covers both the @backend/* alias and any relative path that climbs into backend/."
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["src/backend/agent/index.ts", "src/backend/agent/agents.ts"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": ["@tui/*", "**/tui/**"],
										"message": "backend/ cannot import from tui/. Covers both the @tui/* alias and any relative path that climbs into tui/."
									},
									{
										"group": [
											"./agents/*/tools",
											"./agents/*/tools/*",
											"./agents/*/tools/**",
											"@backend/agent/agents/*/tools",
											"@backend/agent/agents/*/tools/*",
											"@backend/agent/agents/*/tools/**",
											"**/backend/agent/agents/*/tools",
											"**/backend/agent/agents/*/tools/*",
											"**/backend/agent/agents/*/tools/**"
										],
										"message": "The agent shell must not import custom-agent tool internals. Re-export public state/helpers from the agent folder index.ts instead."
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["src/tui/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": [
											"@backend/agent/agents/*",
											"@backend/agent/agents/**",
											"**/backend/agent/agents/*",
											"**/backend/agent/agents/**"
										],
										"message": "TUI must use @backend/agent public APIs, not custom-agent internals."
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["test/**"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	]
}
