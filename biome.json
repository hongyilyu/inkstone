{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"files": {
		"includes": ["src/**/*.{ts,tsx}"]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": "off",
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/backend/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": ["@tui/*", "**/tui/**"],
										"message": "backend/ cannot import from tui/. Covers both the @tui/* alias and any relative path that climbs into tui/."
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["src/bridge/**"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": ["@tui/*", "**/tui/**"],
										"message": "bridge/ cannot import from tui/. Covers both the @tui/* alias and any relative path that climbs into tui/."
									},
									{
										"group": ["@backend/*", "**/backend/**"],
										"message": "bridge/ cannot import from backend/. Covers both the @backend/* alias and any relative path that climbs into backend/."
									}
								]
							}
						}
					}
				}
			}
		}
	]
}
