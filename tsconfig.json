{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // Layer-boundary aliases. Cross-layer imports use these (e.g. @tui/app);
    // intra-layer imports stay relative. Boundary rules in biome.json
    // restrict which aliases each layer can import.
    "baseUrl": ".",
    "paths": {
      "@backend/*": ["src/backend/*"],
      "@bridge/*": ["src/bridge/*"],
      "@tui/*": ["src/tui/*"]
    }
  }
}
